    "db:init": "ts-node-dev src/scripts/db-init.ts",
    "db:verify": "ts-node-dev src/scripts/db-verify.ts",
    "db:migrate:fase2a": "ts-node-dev src/scripts/migrate-fase2a.ts",
    "db:verify:fase2a": "ts-node-dev src/scripts/verify-fase2a.ts"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.45.0",
    "axios": "^1.7.7",
    "date-fns": "^3.6.0",
    "date-fns-tz": "^3.1.3",
    "dotenv": "^17.4.1",
    "node-cron": "^3.0.3",
    "node-telegram-bot-api": "^0.66.0",
    "pino": "^9.4.0",
    "pino-pretty": "^11.2.2",
    "playwright": "^1.48.0",
    "postgres": "^3.4.9",
    "uuid": "^10.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/node-cron": "^3.0.11",
    "@types/node-telegram-bot-api": "^0.64.7",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.5.0"
