NODE_ENV=development
LOG_LEVEL=info
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_DB_URL=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_SEND_TIMEOUT_MS=15000
TELEGRAM_MAX_RETRIES=5
TELEGRAM_INITIAL_RETRY_DELAY_MS=1500
TELEGRAM_RETRY_BACKOFF_MULTIPLIER=2
TELEGRAM_MAX_RETRY_DELAY_MS=10000
PLAYWRIGHT_HEADLESS=true
COLLECT_INTERVAL_MINUTES=30
DAILY_SUMMARY_HOUR=7
APP_TIMEZONE=America/Mexico_City
RAILWAY_ENVIRONMENT=

# Proxy Options
PROXY_ENABLED=false
HTTP_PROXY=
HTTPS_PROXY=

# Compras MX Incremental Control
COMPRASMX_SEED_URL=https://upcp-compranet.hacienda.gob.mx/siete/concursos
COMPRASMX_MAX_LIST_PAGES=5
COMPRASMX_STOP_AFTER_KNOWN_STREAK=15
COMPRASMX_INCREMENTAL_LOOKBACK_HOURS=72
COMPRASMX_DAILY_RECHECK_HOUR=8

# External Leads OSINT — apagado por defecto; no afecta ComprasMX si permanece false.
ENABLE_EXTERNAL_LEADS_OSINT=false
EXTERNAL_LEADS_DRY_RUN=true
EXTERNAL_LEADS_MAX_RESULTS_PER_RUN=5
EXTERNAL_LEADS_MIN_SCORE=60
EXTERNAL_LEADS_LOOKBACK_DAYS=180
EXTERNAL_LEADS_MORELOS_ONLY=true
EXTERNAL_LEADS_TARGET_LOCATIONS=
EXTERNAL_LEADS_TELEGRAM_ENABLED=false
COMMERCIAL_MATCHING_ENABLED=true
COMMERCIAL_MATCHING_MIN_SCORE=60
COMMERCIAL_MATCHING_REQUIRE_TERRITORY=true
COMMERCIAL_MATCHING_DEBUG=true
EXTERNAL_LEADS_DISCOVERY_MODE=true
EXTERNAL_LEADS_DEBUG_DISCARDS=true
EXTERNAL_LEADS_SAVE_LOW_SCORE_CANDIDATES=false
EXTERNAL_LEADS_MAX_RAW_RESULTS_PER_SOURCE=50
EXTERNAL_LEADS_SOURCE_TIMEOUT_MS=15000

# Token para endpoints internos /api/topes/* y /api/licitaciones/evaluar-modalidad
# Header esperado: x-internal-token
INTERNAL_API_TOKEN=

# Token para endpoints /api/licitaciones/recientes y /api/licitaciones/:id/ficha
# Header esperado: x-api-key
INTERNAL_API_KEY=

# Financial Ceiling Radar — módulo de análisis de techo financiero
# Activa el comando /techo en Telegram (solo bajo demanda, no automático)
ENABLE_FINANCIAL_CEILING_COMMAND=true
# Análisis automático por cada alerta (dejar en false — solo activar con mucho cuidado)
ENABLE_FINANCIAL_CEILING_ENRICHMENT=false

# AI Configuration (OpenRouter + Gemma 4)
AI_PROVIDER=openrouter
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
PRIMARY_AI_MODEL=google/gemma-4-31b-it:free

# Alert Filter — ventanas de tiempo y límites
ALERT_NEW_LOOKBACK_HOURS=48
ALERT_ACTIVE_MAX_AGE_DAYS=21
ALERT_DESIERTA_LOOKBACK_DAYS=10
ALERT_INCLUDE_HISTORICAL=false
ALERT_MAX_PER_CYCLE=25
DAILY_SUMMARY_MAX_ITEMS=40
DAILY_SUMMARY_EXCLUDE_OLD_CLOSED=true
